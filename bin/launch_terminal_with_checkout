#!/usr/bin/bash

ARCH=`eval uname -m`

CMD="$HOME/code/operating_system/tool/bin/$ARCH/application_build_helper --git-checkout; exec bash"

launch()
{

   cd $1

   if [[ "$XDG_CURRENT_DESKTOP" == "KDE" ]]; then

      /usr/bin/konsole -e bash -c "$2"

   elif [[ "$XDG_CURRENT_DESKTOP" == "XFCE" ]]; then

      /usr/bin/xfce4-terminal  -e "bash -lc '$2'"

   elif [[ "$XDG_CURRENT_DESKTOP" == *"LXQt"* ]]; then

      /usr/bin/qterminal -e bash -c "$2"

   else

      /usr/bin/gnome-terminal -- bash -c "$2"

   fi

}

launch $1 "$CMD"



